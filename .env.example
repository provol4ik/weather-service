# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# OpenWeatherMap API keys, comma-separated.
# Used to seed data/apis.csv on first start (when the CSV is empty/missing).
# After the CSV exists, edits via the API/Tkinter client are the source of truth.
OWM_API_KEYS=your_key_1,your_key_2

# Bearer token for mutating /apis* endpoints and unmasked GET /apis.
# Leave empty to run unauthenticated (NOT recommended on an exposed port).
# Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=
